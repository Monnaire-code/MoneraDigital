# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/monera_digital

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here-change-in-production

# Encryption Key (Required for 2FA secret encryption)
# MUST be exactly 64 hexadecimal characters (256 bits / 32 bytes)
# Generation methods:
#   - Linux/Mac: openssl rand -hex 32
#   - Go: fmt.Sprintf("%x", make([]byte, 32))
#   - Python: python3 -c "import secrets; print(secrets.token_hex(32))"
# Example key (DO NOT USE IN PRODUCTION - generate your own):
ENCRYPTION_KEY=your-encryption-key-here-64-hex-characters

# Backend Port
PORT=8081

# API Configuration (Unified)
# Frontend uses VITE_API_BASE_URL (Vite env var, available in browser)
# Vercel serverless functions use BACKEND_URL (Node.js env var, server-side only)
# Development: Leave BACKEND_URL empty to use Vite proxy (/api -> http://localhost:8081)
# Production: Set BACKEND_URL to your backend URL for Vercel functions
# Example: BACKEND_URL=https://api.moneradigital.com
#VITE_API_BASE_URL=https://api.moneradigital.com
BACKEND_URL=https://api.moneradigital.com

# Application Environment: production | local | test
# Controls coin_chains seed data: production = mainnet 8 coinKeys, others = testnet 3 coinKeys
APP_ENV=local

# Safeheron Wallet Integration (Phase 1, v1.6)
# Base URL: production = https://api.safeheron.com, sandbox = https://api.safeheron.vip
SAFEHERON_API_BASE_URL=https://api.safeheron.vip
SAFEHERON_API_KEY=<paste-api-key-here>
# RSA keys are referenced by file path (not PEM content). Operators must:
#   mkdir -p secrets && chmod 0700 secrets
#   place the PEM files below, then:
#     chmod 0600 secrets/safeheron-private.pem
#     chmod 0644 secrets/safeheron-platform-pub.pem secrets/safeheron-webhook-pub.pem
# secrets/ is in .gitignore. See SPEC §10.1 for rationale (v1.6).
# NOTE: WEBHOOK_PRIVATE_KEY_PATH 通常指向同一把 client API 私钥 —— Safeheron
# 默认用客户端的 RSA 私钥解密 webhook payload，仅在 Console 单独配置 webhook
# 密钥对时才需要独立文件。
SAFEHERON_PRIVATE_KEY_PATH=./secrets/safeheron-private.pem
SAFEHERON_PLATFORM_PUBLIC_KEY_PATH=./secrets/safeheron-platform-pub.pem
SAFEHERON_WEBHOOK_PUBLIC_KEY_PATH=./secrets/safeheron-webhook-pub.pem
SAFEHERON_WEBHOOK_PRIVATE_KEY_PATH=./secrets/safeheron-private.pem
# Comma-separated IPs allowed to call the webhook endpoint (empty = allow all, for local dev)
SAFEHERON_WEBHOOK_ALLOWED_IPS=18.162.105.64,18.167.22.59,18.167.21.182

# Wallet Config Registry refresh interval (default: 60s)
WALLET_CONFIG_REFRESH_INTERVAL=60s

# Address Pool Replenisher settings
# Check interval (default: 10m)
POOL_REPLENISH_INTERVAL=10m
# EVM pool: trigger replenish when available count < low watermark, fill to target
POOL_LOW_WATERMARK_EVM=50
POOL_TARGET_CAPACITY_EVM=100
# TRON pool: same logic
POOL_LOW_WATERMARK_TRON=50
POOL_TARGET_CAPACITY_TRON=100

# Alert Configuration
# Feishu (Lark) robot webhook URL for operational alerts
ALERT_WEBHOOK_URL=
# Comma-separated email recipients for critical alerts
ALERT_EMAIL_RECIPIENTS=ops@moneradigital.com

# Email Service (Resend)
RESEND_API_KEY=your-resend-api-key
SENDER_EMAIL=ops@moneradigital.com

# Application URL
APP_URL=https://moneradigital.com

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Monnaire Core API (Wallet Service)
# Testing: http://198.13.57.142:8080
# Production: https://core.monnaire.com
MONNAIRE_CORE_API_URL=http://198.13.57.142:8080

# Deposit Worker
DEPOSIT_WORKER_INTERVAL=1s

# KYT Compliance Screening (Phase 1, v1.5)
KYT_ENABLED=true                       # APP_ENV=production requires true; local/test can be false
KYT_TIMEOUT=20m                        # KYT_PENDING timeout threshold
KYT_SCAN_INTERVAL=1m                   # Timeout scan ticker interval
AML_POLL_INTERVAL=100s                 # Active KYT result poll (aml_risk_level=PENDING); default 100s
KYT_ORPHAN_ALERT_MAX_RETRY=100         # Max retries for orphan AML_KYT_ALERT

# Timezone Configuration
# Used for interest calculation and scheduled tasks
# Default: Asia/Shanghai (UTC+8)
TIME_ZONE=Asia/Shanghai
