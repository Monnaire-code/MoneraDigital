# Database Configuration
# SECURITY (C-1 audit, 2026-06-05):
#   The previous literal Neon connection string that lived in this file
#   and in many source files (seed.ts, scripts/cleanup.go, cmd/add_balance,
#   cmd/delete_orders, cmd/db_check, cmd/wealth_test, plus several docs)
#   leaked the production owner password. The password has been rotated
#   in Neon and the leaked literals have been redacted from tracked files.
#   Do NOT re-introduce a real production DSN into this file or any
#   tracked source file. Use a local/staging credential here, and the
#   real production value lives only in your local .env (gitignored)
#   and the deployment secret store. See docs/security/ROTATION_RUNBOOK.md.
DATABASE_URL=postgresql://user:password@localhost:5432/monera_digital

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here-change-in-production

# Encryption Key (Required for 2FA secret encryption)
# MUST be exactly 64 hexadecimal characters (256 bits / 32 bytes)
# Generation methods:
#   - Linux/Mac: openssl rand -hex 32
#   - Go: fmt.Sprintf("%x", make([]byte, 32))
#   - Python: python3 -c "import secrets; print(secrets.token_hex(32))"
# Example key (DO NOT USE IN PRODUCTION - generate your own):
ENCRYPTION_KEY=your-encryption-key-here-64-hex-characters

# Backend Port
PORT=8081

# API Configuration (Unified)
# Frontend uses VITE_API_BASE_URL (Vite env var, available in browser)
# Vercel serverless functions use BACKEND_URL (Node.js env var, server-side only)
# Development: Leave BACKEND_URL empty to use Vite proxy (/api -> http://localhost:8081)
# Production: Set BACKEND_URL to your backend URL for Vercel functions
# Example: BACKEND_URL=https://api.moneradigital.com
#VITE_API_BASE_URL=https://api.moneradigital.com
BACKEND_URL=https://api.moneradigital.com

# Application Environment: production | local | test
APP_ENV=local

# Safeheron Wallet Integration (Phase 1, v1.6)
# Base URL: https://api.safeheron.vip（所有环境统一使用此地址）
SAFEHERON_API_BASE_URL=https://api.safeheron.vip
SAFEHERON_API_KEY=<paste-api-key-here>
# RSA keys are referenced by file path (not PEM content). Operators must:
#   mkdir -p secrets && chmod 0700 secrets
#   place the PEM files below, then:
#     chmod 0600 secrets/safeheron-private.pem
#     chmod 0644 secrets/safeheron-platform-pub.pem secrets/safeheron-webhook-pub.pem
# secrets/ is in .gitignore. See SPEC §10.1 for rationale (v1.6).
# NOTE: WEBHOOK_PRIVATE_KEY_PATH 通常指向同一把 client API 私钥 —— Safeheron
# 默认用客户端的 RSA 私钥解密 webhook payload，仅在 Console 单独配置 webhook
# 密钥对时才需要独立文件。
SAFEHERON_PRIVATE_KEY_PATH=./secrets/safeheron-private.pem
SAFEHERON_PLATFORM_PUBLIC_KEY_PATH=./secrets/safeheron-platform-pub.pem
SAFEHERON_WEBHOOK_PUBLIC_KEY_PATH=./secrets/safeheron-webhook-pub.pem
SAFEHERON_WEBHOOK_PRIVATE_KEY_PATH=./secrets/safeheron-private.pem
# Comma-separated IPs allowed to call the webhook endpoint (empty = allow all, for local dev)
SAFEHERON_WEBHOOK_ALLOWED_IPS=18.162.105.64,18.167.22.59,18.167.21.182

# Wallet Config Registry refresh interval (default: 60s)
WALLET_CONFIG_REFRESH_INTERVAL=60s

# Address Pool Replenisher settings
# Check interval (default: 10m)
POOL_REPLENISH_INTERVAL=10m
# EVM pool: trigger replenish when available count < low watermark, fill to target
POOL_LOW_WATERMARK_EVM=50
POOL_TARGET_CAPACITY_EVM=100
# TRON pool: same logic
POOL_LOW_WATERMARK_TRON=50
POOL_TARGET_CAPACITY_TRON=100

# Alert Configuration
# Feishu (Lark) robot webhook URL for operational alerts
ALERT_WEBHOOK_URL=
# Signing secret from Lark bot security settings (leave empty if signing is disabled)
ALERT_WEBHOOK_SIGN_SECRET=
# Comma-separated email recipients for critical alerts
ALERT_EMAIL_RECIPIENTS=ops@moneradigital.com

# Email Service (Resend)
RESEND_API_KEY=your-resend-api-key
SENDER_EMAIL=ops@moneradigital.com

# Application URL
APP_URL=https://moneradigital.com

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Monnaire Core API (Wallet Service)
# Testing: http://198.13.57.142:8080
# Production: https://core.monnaire.com
MONNAIRE_CORE_API_URL=http://198.13.57.142:8080

# Deposit Worker
DEPOSIT_WORKER_INTERVAL=1s

# KYT Compliance Screening (Phase 1, v1.5)
KYT_ENABLED=true                       # APP_ENV=production requires true; local/test can be false
KYT_TIMEOUT=20m                        # KYT_PENDING 终态兜底阈值（强制 MANUAL_REVIEW）
KYT_SCAN_INTERVAL=1m                   # 超时扫描 ticker 间隔
AML_FIRST_POLL_DELAY=5m               # KYT 安全网最小等待（webhook ~78s 先到；5m 后才主动轮询）
AML_POLL_INTERVAL=60s                  # AML 安全网扫描 ticker 间隔（SQL minAge 条件过滤，5m 内不触发）
KYT_ORPHAN_ALERT_MAX_RETRY=100         # Max retries for orphan AML_KYT_ALERT

# Timezone Configuration
# Used for interest calculation and scheduled tasks
# Default: Asia/Shanghai (UTC+8)
TIME_ZONE=Asia/Shanghai

# Company Fund Transaction Ingestion
# Disabled by default. When enabled, the Go backend loads configured company
# fund accounts into an in-process snapshot cache and refreshes it every 1m.
# This feature deliberately does not use Redis and does not reuse ENCRYPTION_KEY.
COMPANY_FUND_ENABLED=false
# Production starts the account cache, durable-event worker, reconciliation,
# Safeheron bridge compensator, and USD valuation loops whenever
# COMPANY_FUND_ENABLED=true. Set false only for focused/local tests.
COMPANY_FUND_START_BACKGROUND_WORKERS=true
COMPANY_FUND_ACCOUNT_REFRESH_INTERVAL=1m
# Generate an independent 32-byte AES-256 key (64 lowercase/uppercase hex
# characters are accepted). Leave blank in this tracked example.
COMPANY_FUND_PAYLOAD_KEY=
COMPANY_FUND_PAYLOAD_KEY_VERSION=payload-v1
COMPANY_FUND_PAYLOAD_RETENTION=48h
COMPANY_FUND_PAYLOAD_LEGAL_HOLD=false
# Future-reserved management-backend secret. The Go backend currently registers
# no /api/company-fund/finance/* routes because the separate management system
# reads and maintains the shared database directly.
# COMPANY_FUND_ADMIN_KEY=

# Provider-event worker: PostgreSQL leases/retry state are authoritative across
# replicas; owner values should be unique per replica if explicitly supplied.
COMPANY_FUND_EVENT_POLL_INTERVAL=1s
COMPANY_FUND_EVENT_DRAIN_LIMIT=100
COMPANY_FUND_EVENT_LEASE_OWNER=
COMPANY_FUND_EVENT_LEASE_DURATION=1m
COMPANY_FUND_EVENT_LEASE_RENEW_INTERVAL=20s
COMPANY_FUND_EVENT_RETRY_INITIAL_DELAY=30s
COMPANY_FUND_EVENT_RETRY_MAX_DELAY=1h

# Daily REST compensation uses Asia/Singapore (UTC+8) at 03:00 by default.
# The catch-up window records independent durable sync runs for the last seven
# eligible local dates; it never uses the host machine's local timezone.
COMPANY_FUND_RECONCILIATION_POLL_INTERVAL=1m
COMPANY_FUND_RECONCILIATION_TIME_ZONE=Asia/Singapore
COMPANY_FUND_RECONCILIATION_DAILY_TIME=03:00
COMPANY_FUND_RECONCILIATION_CATCH_UP_DAYS=7
# After the primary daily pass, run one independently keyed rolling overlap
# re-scan for late terminal/corrected provider statuses. The key is stable for
# the eligible local date, while tomorrow opens a new key whose range still
# overlaps prior days. Set 0 explicitly to disable this repair pass.
COMPANY_FUND_LATE_STATUS_OVERLAP_DAYS=7
COMPANY_FUND_RECONCILIATION_LEASE_OWNER=
COMPANY_FUND_RECONCILIATION_LEASE_DURATION=5m
COMPANY_FUND_RECONCILIATION_RETRY_INITIAL_DELAY=1m
COMPANY_FUND_RECONCILIATION_RETRY_MAX_DELAY=1h
COMPANY_FUND_RECONCILIATION_FINALIZE_TIMEOUT=10s

# Safeheron webhook events are signature-verified and retained by the existing
# webhook receiver. This collector only repairs a durable raw-event → company-
# fund provider-event bridge; it does not touch the deposit worker lifecycle.
# Safeheron history REST compensation has no minimum-amount filter: dust and
# phishing/pollution candidates must reach the ledger risk policy.
COMPANY_FUND_SAFEHERON_HISTORY_PAGE_SIZE=100
COMPANY_FUND_SAFEHERON_HISTORY_MAX_PAGES=100
COMPANY_FUND_SAFEHERON_COLLECTOR_INTERVAL=1m
COMPANY_FUND_SAFEHERON_COLLECTOR_BATCH_SIZE=100

# Airwallex (optional company-fund adapters)
# The Go backend obtains a short-lived bearer token from Client ID/API key; no
# browser login or API-key-only business request is used. Pin the approved
# Airwallex date version before enabling this adapter.
AIRWALLEX_BASE_URL=https://api.airwallex.com
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
# Required for company-fund Financial Transactions reconciliation. It must be
# an exact match for the provider_account_key of exactly one enabled
# AIRWALLEX company_fund_accounts row. Blank, whitespace, mismatch, or more
# than one enabled Airwallex account disables the REST adapter and webhook.
# Multi-account support needs one separately scoped client/credential per
# account and is intentionally not inferred from webhook payload fields.
AIRWALLEX_LOGIN_AS=
AIRWALLEX_API_VERSION=
# The raw HMAC-verified webhook is served directly by Go at
# POST /api/webhooks/airwallex. Do not add a Vercel proxy/forwarder for it.
# Its event version must exactly equal the strict JSON event_version below.
AIRWALLEX_WEBHOOK_VERSION=
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_WEBHOOK_TIMESTAMP_TOLERANCE=5m
# Webhook delivery only wakes a bounded REST scan for the one eligible
# x-login-as account. The webhook account_id/org_id is never used to select an
# account; if a registry refresh invalidates single-account ownership, ingress
# fails closed and no event is queued. Default lookback is 24h; the runtime
# rejects values over 7d. Internal [start,end) windows are sent as inclusive
# ISO-8601/RFC3339Nano provider filters with end-1ns to avoid overlap.
COMPANY_FUND_AIRWALLEX_WEBHOOK_LOOKBACK=24h
AIRWALLEX_FINANCIAL_TRANSACTIONS_PAGE_SIZE=100
AIRWALLEX_FINANCIAL_TRANSACTIONS_MAX_PAGES=100
# Required before any Airwallex reconciler or webhook is exposed. This is
# strict backend-only JSON: exact provider account/type/source/currency/status
# rules, version pins, and approved evidence references. Blank or invalid JSON
# disables Airwallex ingestion; source_id, webhook account_id, and organisation
# identifiers are never inferred into account/relationship mappings.
# Example shape only (keep the actual approved mapping in secret/config mgmt):
# {"enabled":true,"api_version":"YYYY-MM-DD","schema_version":"schema-v1","event_version":"event-v1","mapping_version":"mapping-v1","fact_version":1,"rules":[...]}
AIRWALLEX_FINANCIAL_TRANSACTIONS_RUNTIME_CONFIG=

# Current USD valuation (process-local Go memory cache; no Redis). The rate
# refresh ticker and valuation repair sweep ticker are independent: refresh
# alone calls CoinGecko, while a faster sweep never multiplies provider calls.
# Both run once immediately at startup by default and only use explicit
# account-asset policy mappings. The demo API key is optional; never commit a
# real key.
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_DEMO_API_KEY=
COMPANY_FUND_USD_RATE_REFRESH_INTERVAL=5m
COMPANY_FUND_USD_RATE_CACHE_TTL=10m
COMPANY_FUND_USD_RATE_CACHE_MAX_AGE=60m
COMPANY_FUND_USD_VALUATION_SWEEP_INTERVAL=1m
COMPANY_FUND_USD_VALUATION_SWEEP_BATCH=100
COMPANY_FUND_USD_VALUATION_POLICY_VERSION=current-usd-v1
# In company_fund_account_asset_policies, use an explicit CoinGecko mapping:
# valuation_provider_asset_id / CoinGeckoID may be a coin id (e.g. bitcoin),
# a platform+contract pair, or fiat:<CODE> for fiat only (fiat:JPY, fiat:SGD,
# fiat:HKD, fiat:CNY). fiat:<CODE> must exactly match the policy currency, must
# not include platform/contract, and fiat:USD must not be configured (USD is
# parity). Fiat USD conversion comes from CoinGecko /exchange_rates, whose
# source is approximately five-minute updated; these values are current /
# provisional at ingestion, never transaction-time historical prices.
